10 REM Colour Flood
20 BORDER 0
30 CLS
40 PRINT "== Colour Flood =="
50 PRINT
60 PRINT "Press a key for each pattern!"
70 IF INKEY$ = "" THEN GO TO 70
80 CLS
90 FOR c = 0 TO 6
100 PAPER c
110 FOR i = 1 TO 96
120 PRINT " ";
130 NEXT i
140 NEXT c
150 BEEP 0.1, 12
160 IF INKEY$ = "" THEN GO TO 160
170 CLS
180 LET a = 2
190 LET b = 6
200 FOR r = 1 TO 22
210 FOR c = 1 TO 16
220 PAPER a
230 PRINT " ";
240 PAPER b
250 PRINT " ";
260 NEXT c
270 LET t = a
280 LET a = b
290 LET b = t
300 NEXT r
310 BEEP 0.1, 12
320 IF INKEY$ = "" THEN GO TO 320
330 CLS
340 FOR i = 1 TO 704
350 PAPER INT (RND * 8)
360 BRIGHT INT (RND * 2)
370 PRINT " ";
380 NEXT i
390 BRIGHT 0
400 BEEP 0.1, 12
410 IF INKEY$ = "" THEN GO TO 410
420 BORDER 7
430 PAPER 7
440 INK 0
450 CLS
460 PRINT "== Colour Flood =="
470 PRINT
480 PRINT "Well done!"
