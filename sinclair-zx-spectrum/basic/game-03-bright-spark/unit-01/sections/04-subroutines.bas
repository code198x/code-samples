2000 REM === Draw all panels ===
2010 FOR r=2 TO 9: PRINT AT r,1; PAPER 2;"              ": NEXT r
2020 PRINT AT 5,7; PAPER 2; INK 7;"1"
2030 FOR r=2 TO 9: PRINT AT r,17; PAPER 1;"              ": NEXT r
2040 PRINT AT 5,23; PAPER 1; INK 7;"2"
2050 FOR r=12 TO 19: PRINT AT r,1; PAPER 4;"              ": NEXT r
2060 PRINT AT 15,7; PAPER 4; INK 0;"3"
2070 FOR r=12 TO 19: PRINT AT r,17; PAPER 6;"              ": NEXT r
2080 PRINT AT 15,23; PAPER 6; INK 0;"4"
2090 RETURN
2100 REM === Flash panel 1 (red) ===
2110 FOR r=2 TO 9: PRINT AT r,1; PAPER 2; BRIGHT 1;"              ": NEXT r
2120 PRINT AT 5,7; PAPER 2; BRIGHT 1; INK 7;"1"
2130 BEEP 0.3,0
2140 FOR r=2 TO 9: PRINT AT r,1; PAPER 2;"              ": NEXT r
2150 PRINT AT 5,7; PAPER 2; INK 7;"1"
2160 RETURN
2200 REM === Flash panel 2 (blue) ===
2210 FOR r=2 TO 9: PRINT AT r,17; PAPER 1; BRIGHT 1;"              ": NEXT r
2220 PRINT AT 5,23; PAPER 1; BRIGHT 1; INK 7;"2"
2230 BEEP 0.3,4
2240 FOR r=2 TO 9: PRINT AT r,17; PAPER 1;"              ": NEXT r
2250 PRINT AT 5,23; PAPER 1; INK 7;"2"
2260 RETURN
2300 REM === Flash panel 3 (green) ===
2310 FOR r=12 TO 19: PRINT AT r,1; PAPER 4; BRIGHT 1;"              ": NEXT r
2320 PRINT AT 15,7; PAPER 4; BRIGHT 1; INK 0;"3"
2330 BEEP 0.3,7
2340 FOR r=12 TO 19: PRINT AT r,1; PAPER 4;"              ": NEXT r
2350 PRINT AT 15,7; PAPER 4; INK 0;"3"
2360 RETURN
2400 REM === Flash panel 4 (yellow) ===
2410 FOR r=12 TO 19: PRINT AT r,17; PAPER 6; BRIGHT 1;"              ": NEXT r
2420 PRINT AT 15,23; PAPER 6; BRIGHT 1; INK 0;"4"
2430 BEEP 0.3,12
2440 FOR r=12 TO 19: PRINT AT r,17; PAPER 6;"              ": NEXT r
2450 PRINT AT 15,23; PAPER 6; INK 0;"4"
2460 RETURN
3000 REM === Centre text t$ on row r ===
3010 PRINT AT r,(32-LEN t$)/2;t$
3020 RETURN
3100 REM === Clear row r ===
3110 PRINT AT r,1;"                              "
3120 RETURN
