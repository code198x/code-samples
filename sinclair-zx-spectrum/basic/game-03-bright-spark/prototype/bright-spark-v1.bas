  10 REM Bright Spark
  20 RANDOMIZE
  30 BORDER 0: PAPER 0: INK 7: CLS
  40 LET s$=""
  50 LET score=0
 100 REM === Draw panels ===
 110 GO SUB 2000
 120 LET r=0: LET t$="BRIGHT SPARK": INK 6: BRIGHT 1: GO SUB 3000: BRIGHT 0
 130 PRINT AT 10,14; INK 5;"vs"
 200 REM === Add to sequence ===
 210 LET p=INT (RND*4)+1
 220 LET p$="1"
 230 IF p=2 THEN LET p$="2"
 240 IF p=3 THEN LET p$="3"
 250 IF p=4 THEN LET p$="4"
 260 LET s$=s$+p$
 270 LET r=21: GO SUB 3100: LET t$="Watch... Round "+STR$ (LEN s$): INK 5: GO SUB 3000
 280 PAUSE 50
 300 REM === Play sequence ===
 310 FOR i=1 TO LEN s$
 320 IF s$(i)="1" THEN GO SUB 2100
 330 IF s$(i)="2" THEN GO SUB 2200
 340 IF s$(i)="3" THEN GO SUB 2300
 350 IF s$(i)="4" THEN GO SUB 2400
 360 PAUSE 15
 370 NEXT i
 400 REM === Player repeats ===
 410 LET r=21: GO SUB 3100: LET t$="Your turn!": INK 6: BRIGHT 1: GO SUB 3000: BRIGHT 0
 420 FOR i=1 TO LEN s$
 430 LET k$=INKEY$
 440 IF k$="" THEN GO TO 430
 450 IF k$="1" THEN GO SUB 2100: GO TO 500
 460 IF k$="2" THEN GO SUB 2200: GO TO 500
 470 IF k$="3" THEN GO SUB 2300: GO TO 500
 480 IF k$="4" THEN GO SUB 2400: GO TO 500
 490 GO TO 430
 500 REM === Check answer ===
 510 IF k$<>s$(i) THEN GO TO 700
 520 PAUSE 5
 530 IF INKEY$<>"" THEN GO TO 530
 540 NEXT i
 550 REM === Correct! ===
 560 LET score=score+1
 570 LET r=21: GO SUB 3100: LET t$="Correct! Score: "+STR$ score: INK 4: GO SUB 3000
 580 BEEP 0.15,20: BEEP 0.15,24
 590 PAUSE 30
 600 GO TO 200
 700 REM === Wrong! ===
 710 BEEP 0.5,-10
 720 BORDER 2: PAUSE 25: BORDER 0
 730 LET r=10: LET t$="WRONG!": INK 2: BRIGHT 1: FLASH 1: GO SUB 3000: FLASH 0: BRIGHT 0
 740 LET r=12: LET t$="Score: "+STR$ score: INK 5: GO SUB 3000
 750 LET r=14: LET t$="Sequence was "+STR$ (LEN s$)+" long": INK 7: GO SUB 3000
 760 STOP
2000 REM === Draw all panels ===
2010 FOR r=2 TO 9: PRINT AT r,1; PAPER 2;"              ": NEXT r
2020 PRINT AT 5,7; PAPER 2; INK 7;"1"
2030 FOR r=2 TO 9: PRINT AT r,17; PAPER 1;"              ": NEXT r
2040 PRINT AT 5,23; PAPER 1; INK 7;"2"
2050 FOR r=12 TO 19: PRINT AT r,1; PAPER 4;"              ": NEXT r
2060 PRINT AT 15,7; PAPER 4; INK 0;"3"
2070 FOR r=12 TO 19: PRINT AT r,17; PAPER 6;"              ": NEXT r
2080 PRINT AT 15,23; PAPER 6; INK 0;"4"
2090 RETURN
2100 REM === Flash panel 1 (red) ===
2110 FOR r=2 TO 9: PRINT AT r,1; PAPER 2; BRIGHT 1;"              ": NEXT r
2120 PRINT AT 5,7; PAPER 2; BRIGHT 1; INK 7;"1"
2130 BEEP 0.3,0
2140 FOR r=2 TO 9: PRINT AT r,1; PAPER 2;"              ": NEXT r
2150 PRINT AT 5,7; PAPER 2; INK 7;"1"
2160 RETURN
2200 REM === Flash panel 2 (blue) ===
2210 FOR r=2 TO 9: PRINT AT r,17; PAPER 1; BRIGHT 1;"              ": NEXT r
2220 PRINT AT 5,23; PAPER 1; BRIGHT 1; INK 7;"2"
2230 BEEP 0.3,4
2240 FOR r=2 TO 9: PRINT AT r,17; PAPER 1;"              ": NEXT r
2250 PRINT AT 5,23; PAPER 1; INK 7;"2"
2260 RETURN
2300 REM === Flash panel 3 (green) ===
2310 FOR r=12 TO 19: PRINT AT r,1; PAPER 4; BRIGHT 1;"              ": NEXT r
2320 PRINT AT 15,7; PAPER 4; BRIGHT 1; INK 0;"3"
2330 BEEP 0.3,7
2340 FOR r=12 TO 19: PRINT AT r,1; PAPER 4;"              ": NEXT r
2350 PRINT AT 15,7; PAPER 4; INK 0;"3"
2360 RETURN
2400 REM === Flash panel 4 (yellow) ===
2410 FOR r=12 TO 19: PRINT AT r,17; PAPER 6; BRIGHT 1;"              ": NEXT r
2420 PRINT AT 15,23; PAPER 6; BRIGHT 1; INK 0;"4"
2430 BEEP 0.3,12
2440 FOR r=12 TO 19: PRINT AT r,17; PAPER 6;"              ": NEXT r
2450 PRINT AT 15,23; PAPER 6; INK 0;"4"
2460 RETURN
3000 REM === Centre text t$ on row r ===
3010 PRINT AT r,(32-LEN t$)/2;t$
3020 RETURN
3100 REM === Clear row r ===
3110 PRINT AT r,1;"                              "
3120 RETURN
