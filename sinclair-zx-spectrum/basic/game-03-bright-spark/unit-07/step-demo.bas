  10 CLS
  20 PRINT "Counting up:"
  30 FOR i=1 TO 10
  40 PRINT i; " ";
  50 NEXT i
  60 PRINT
  70 PRINT
  80 PRINT "Counting down:"
  90 FOR i=10 TO 1 STEP -1
 100 PRINT i; " ";
 110 NEXT i
 120 PRINT
 130 PRINT
 140 PRINT "Counting by twos:"
 150 FOR i=0 TO 20 STEP 2
 160 PRINT i; " ";
 170 NEXT i
