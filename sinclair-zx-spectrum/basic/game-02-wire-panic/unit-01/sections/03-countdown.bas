 500 REM === Countdown loop ===
 510 INK 6: LET g=t: GO SUB 2400
 520 REM === Timer bar fill ===
 530 LET f=20-t
 540 IF f>0 THEN INK 2: FOR i=0 TO 5: PLOT 101,89-i: DRAW INT (54*f/20),0: NEXT i
 550 REM === Border colour ===
 560 IF t>14 THEN BORDER 4
 570 IF t>7 THEN IF t<=14 THEN BORDER 6
 580 IF t<=7 THEN BORDER 2
 590 REM === Flash LEDs ===
 600 IF t>10 THEN INK 4: CIRCLE 160,160,2: CIRCLE 168,160,2: CIRCLE 176,160,2
 610 IF t<=10 THEN INK 2: CIRCLE 160,160,2: CIRCLE 168,160,2: CIRCLE 176,160,2
 620 REM === Tick ===
 630 INK 7: BEEP 0.05,t
 640 PAUSE 40
 650 LET k$=INKEY$
 660 IF k$="1" THEN GO TO 800
 670 IF k$="2" THEN GO TO 800
 680 IF k$="3" THEN GO TO 800
 690 IF k$="4" THEN GO TO 800
 700 LET t=t-1
 710 IF t<0 THEN GO TO 900
 720 GO TO 500
