  10 REM Wire Cutter — with tension layers
  20 RANDOMIZE
  30 BORDER 4: PAPER 0: INK 7: CLS
  40 LET w=INT (RND*4)+1
  50 LET w$="1"
  60 IF w=2 THEN LET w$="2"
  70 IF w=3 THEN LET w$="3"
  80 IF w=4 THEN LET w$="4"
  90 LET t=15
 100 LET r=0: LET t$="WIRE CUTTER": INK 2: BRIGHT 1: GO SUB 3000: BRIGHT 0
 110 PRINT AT 17,4; INK 2;"1"; INK 1;"  2"; INK 4;"  3"; INK 6;"  4"
 120 LET r=21: LET t$="Cut a wire: 1 2 3 4": INK 5: GO SUB 3000
 130 REM === Countdown loop ===
 140 PRINT AT 10,14; INK 6; BRIGHT 1;t;" "
 150 REM === Border colour ===
 160 IF t>10 THEN BORDER 4
 170 IF t>5 THEN IF t<=10 THEN BORDER 6
 180 IF t<=5 THEN BORDER 2
 190 REM === Tick ===
 200 BEEP 0.05,t
 210 PAUSE 40
 220 LET k$=INKEY$
 230 IF k$="1" THEN GO TO 310
 240 IF k$="2" THEN GO TO 310
 250 IF k$="3" THEN GO TO 310
 260 IF k$="4" THEN GO TO 310
 270 LET t=t-1
 280 IF t<0 THEN GO TO 400
 290 GO TO 140
 310 IF k$=w$ THEN GO TO 500
 400 REM === Too late ===
 410 BORDER 2
 420 LET r=12: LET t$="Too late!": INK 2: BRIGHT 1: GO SUB 3000: BRIGHT 0
 430 LET r=14: LET t$="Wire was "+w$: INK 5: GO SUB 3000
 440 STOP
 500 REM === Defused ===
 510 BORDER 4
 520 LET r=12: LET t$="DEFUSED!": INK 4: BRIGHT 1: GO SUB 3000: BRIGHT 0
 530 LET r=14: LET t$="Time left: "+STR$ t: INK 5: GO SUB 3000
 540 STOP
3000 REM === Centre text t$ on row r ===
3010 PRINT AT r,(32-LEN t$)/2;t$
3020 RETURN
