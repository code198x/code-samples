 220 REM === LED indicators ===
 230 INK 2: CIRCLE 80,160,2: CIRCLE 88,160,2: CIRCLE 96,160,2
 240 INK 4: CIRCLE 160,160,2: CIRCLE 168,160,2: CIRCLE 176,160,2
 250 REM === Wires from device ===
 260 INK 2: PLOT 80,72: DRAW 0,-40: PLOT 81,72: DRAW 0,-40
 270 INK 1: PLOT 112,72: DRAW 0,-40: PLOT 113,72: DRAW 0,-40
 280 INK 4: PLOT 144,72: DRAW 0,-40: PLOT 145,72: DRAW 0,-40
 290 INK 6: PLOT 176,72: DRAW 0,-40: PLOT 177,72: DRAW 0,-40
 300 REM === Wire labels ===
 310 PRINT AT 19,8; INK 2; BRIGHT 1;"1"
 320 PRINT AT 19,12; INK 1; BRIGHT 1;"2"
 330 PRINT AT 19,16; INK 4; BRIGHT 1;"3"
 340 PRINT AT 19,20; INK 6; BRIGHT 1;"4"
 350 REM === Title and prompt ===
 360 LET r=0: LET t$="WIRE PANIC": INK 2: BRIGHT 1: GO SUB 3000: BRIGHT 0
 370 LET r=21: LET t$="Cut a wire: 1 2 3 4": INK 5: GO SUB 3000
 380 REM === Timer bar outline ===
 390 INK 5: PLOT 100,90: DRAW 56,0: DRAW 0,-8: DRAW -56,0: DRAW 0,8
 400 IF INKEY$<>"" THEN GO TO 400
 500 REM === Countdown loop ===
 510 INK 6: LET g=t: GO SUB 2400
 520 REM === Timer bar fill ===
 530 LET f=20-t
 540 IF f>0 THEN INK 2: FOR i=0 TO 5: PLOT 101,89-i: DRAW INT (54*f/20),0: NEXT i
 550 REM === Border colour ===
 560 IF t>14 THEN BORDER 4
 570 IF t>7 THEN IF t<=14 THEN BORDER 6
 580 IF t<=7 THEN BORDER 2
 590 REM === Flash LEDs ===
 600 IF t>10 THEN INK 4: CIRCLE 160,160,2: CIRCLE 168,160,2: CIRCLE 176,160,2
 610 IF t<=10 THEN INK 2: CIRCLE 160,160,2: CIRCLE 168,160,2: CIRCLE 176,160,2
 620 REM === Tick ===
 630 INK 7: BEEP 0.05,t
 640 PAUSE 40
 650 LET k$=INKEY$
 660 IF k$="1" THEN GO TO 800
 670 IF k$="2" THEN GO TO 800
 680 IF k$="3" THEN GO TO 800
 690 IF k$="4" THEN GO TO 800
 700 LET t=t-1
 710 IF t<0 THEN GO TO 900
 720 GO TO 500
 800 REM === Wire cut ===
 810 IF k$=w$ THEN GO TO 1000
 900 REM === EXPLOSION ===
 910 FOR i=1 TO 25
 920 BORDER INT (RND*8)
 930 BEEP 0.02,INT (RND*40)
 940 NEXT i
 950 BORDER 2
 960 INK 2: LET g=0: GO SUB 2400
 970 LET r=15: LET t$="BOOM!": INK 2: BRIGHT 1: FLASH 1: GO SUB 3000: FLASH 0: BRIGHT 0
 980 LET r=21: GO SUB 3100: LET t$="Correct wire was "+w$: INK 5: GO SUB 3000
 990 STOP
1000 REM === DEFUSED! ===
1010 FOR i=1 TO 15
1020 BORDER 4: BEEP 0.02,25+i*2
1030 BORDER 0: BEEP 0.02,25+i*2
1040 NEXT i
1050 BORDER 4
1060 INK 4: LET g=t: GO SUB 2400
1070 REM === Turn LEDs green ===
1080 INK 4: CIRCLE 80,160,2: CIRCLE 88,160,2: CIRCLE 96,160,2
1090 CIRCLE 160,160,2: CIRCLE 168,160,2: CIRCLE 176,160,2
1100 LET r=15: LET t$="DEFUSED!": INK 4: BRIGHT 1: FLASH 1: GO SUB 3000: FLASH 0: BRIGHT 0
1110 LET r=21: GO SUB 3100: LET t$="Time left: "+STR$ t+" seconds": INK 5: GO SUB 3000
1120 BEEP 0.5,30
1130 STOP
2000 REM === Draw single digit d at px,py ===
2010 RESTORE 9000+d
2020 READ s$
2030 IF s$(1)="1" THEN FOR i=1 TO 6: PLOT px+9,py-i: DRAW 21,0: NEXT i
2040 IF s$(2)="1" THEN FOR i=1 TO 6: PLOT px+i,py-9: DRAW 0,-13: NEXT i
2050 IF s$(3)="1" THEN FOR i=1 TO 6: PLOT px+33+i,py-9: DRAW 0,-13: NEXT i
2060 IF s$(4)="1" THEN FOR i=1 TO 6: PLOT px+9,py-25-i: DRAW 21,0: NEXT i
2070 IF s$(5)="1" THEN FOR i=1 TO 6: PLOT px+i,py-33: DRAW 0,-13: NEXT i
2080 IF s$(6)="1" THEN FOR i=1 TO 6: PLOT px+33+i,py-33: DRAW 0,-13: NEXT i
2090 IF s$(7)="1" THEN FOR i=1 TO 6: PLOT px+9,py-49-i: DRAW 21,0: NEXT i
2100 RETURN
2400 REM === Draw number g centred in device ===
2410 FOR r=3 TO 9
2420 PRINT AT r,7; PAPER 0;"                  "
2430 NEXT r
