  10 REM Wire Panic v2
  20 RANDOMIZE
  30 BORDER 0: PAPER 0: INK 7: CLS
  40 LET w=INT (RND*4)+1
  50 LET w$="1"
  60 IF w=2 THEN LET w$="2"
  70 IF w=3 THEN LET w$="3"
  80 IF w=4 THEN LET w$="4"
  90 LET t=20
 100 REM === Draw device box ===
 110 INK 5: PLOT 40,168: DRAW 176,0: DRAW 0,-96: DRAW -176,0: DRAW 0,96
 120 REM === Inner frame ===
 130 INK 1: PLOT 44,164: DRAW 168,0: DRAW 0,-88: DRAW -168,0: DRAW 0,88
 140 REM === Cogs (circles) ===
 150 INK 5: CIRCLE 64,100,10: CIRCLE 64,100,6
 160 CIRCLE 192,100,10: CIRCLE 192,100,6
 170 REM === Circuit traces ===
 180 INK 1: PLOT 76,100: DRAW 24,0
 190 PLOT 156,100: DRAW 24,0
