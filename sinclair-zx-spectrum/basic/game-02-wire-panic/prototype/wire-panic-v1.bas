  10 REM Wire Panic
  20 RANDOMIZE
  30 BORDER 4: PAPER 0: INK 7: CLS
  40 LET w=INT (RND*4)+1
  50 LET w$="1"
  60 IF w=2 THEN LET w$="2"
  70 IF w=3 THEN LET w$="3"
  80 IF w=4 THEN LET w$="4"
  90 LET t=20
 100 REM === Title ===
 110 PRINT AT 0,10; INK 2; BRIGHT 1;"WIRE PANIC"
 120 REM === Draw fuse ===
 130 FOR i=2 TO 29
 140 PRINT AT 13,i; PAPER 6;" "
 150 NEXT i
 160 REM === Draw wires ===
 170 PRINT AT 17,2; PAPER 2; INK 7; BRIGHT 1;"  WIRE 1  "
 180 PRINT AT 17,18; PAPER 1; INK 7; BRIGHT 1;"  WIRE 2  "
 190 PRINT AT 19,2; PAPER 4; INK 7; BRIGHT 1;"  WIRE 3  "
 200 PRINT AT 19,18; PAPER 6; INK 0; BRIGHT 1;"  WIRE 4  "
 210 PRINT AT 21,5; INK 5;"Press 1, 2, 3 or 4"
 290 IF INKEY$<>"" THEN GO TO 290
 300 REM === Countdown loop ===
 310 LET pc=6: LET g=t: GO SUB 2400
 320 REM === Fuse burn ===
 330 LET f=20-t
 340 IF f>0 THEN PRINT AT 13,f+1; PAPER 0;" "
 350 IF f<27 THEN PRINT AT 13,f+2; PAPER 2; BRIGHT 1;" "
 360 REM === Border colour ===
 370 IF t>14 THEN BORDER 4
 380 IF t>7 THEN IF t<=14 THEN BORDER 6
 390 IF t<=7 THEN BORDER 2
 400 REM === Tick ===
 410 BEEP 0.05,t
 420 PAUSE 40
 430 LET k$=INKEY$
 440 IF k$="1" THEN GO TO 600
 450 IF k$="2" THEN GO TO 600
 460 IF k$="3" THEN GO TO 600
 470 IF k$="4" THEN GO TO 600
 480 LET t=t-1
 490 IF t<0 THEN GO TO 700
 500 GO TO 300
 600 REM === Wire cut ===
 610 IF k$=w$ THEN GO TO 800
 700 REM === EXPLOSION ===
 710 FOR i=1 TO 20
 720 BORDER INT (RND*8)
 730 BEEP 0.03,INT (RND*30)
 740 NEXT i
 750 BORDER 2
 760 LET pc=2: LET g=0: GO SUB 2400
 770 PRINT AT 15,9; INK 2; BRIGHT 1; FLASH 1;"   BOOM!   "; FLASH 0
 780 PRINT AT 21,4; INK 5;" Correct wire was ";w;"   "
 790 STOP
 800 REM === DEFUSED! ===
 810 FOR i=1 TO 10
 820 BORDER 4: BEEP 0.02,25+i*2
 830 BORDER 0: BEEP 0.02,25+i*2
 840 NEXT i
 850 BORDER 4
 860 LET pc=4: LET g=t: GO SUB 2400
 870 PRINT AT 15,8; INK 4; BRIGHT 1; FLASH 1;"  DEFUSED!  "; FLASH 0
 880 PRINT AT 21,5; INK 5;"Time left: ";t;" seconds  "
 890 BEEP 0.5,30
 900 STOP
2000 REM === Draw single digit f ===
2010 RESTORE 9200+f*10
2020 FOR r=0 TO 6
2030 READ a$
2040 FOR q=1 TO LEN a$
2050 IF a$(q)="1" THEN PRINT AT dr+r,dc+q-1; PAPER pc;" "
2060 IF a$(q)="." THEN PRINT AT dr+r,dc+q-1; PAPER 0;" "
2070 NEXT q
2080 NEXT r
2090 RETURN
2400 REM === Draw number g centred ===
2410 FOR r=5 TO 11
2420 PRINT AT r,2; PAPER 0;"                            "
2430 NEXT r
2440 IF g>=100 THEN GO TO 2520
2450 IF g>=10 THEN GO TO 2490
2460 LET dc=14: LET dr=5: LET f=g: GO SUB 2000
2470 RETURN
2490 LET dc=11: LET dr=5: LET f=INT (g/10): GO SUB 2000
2500 LET dc=18: LET dr=5: LET f=g-INT (g/10)*10: GO SUB 2000
2510 RETURN
2520 LET dc=8: LET dr=5: LET f=1: GO SUB 2000
2530 LET dc=14: LET dr=5: LET f=0: GO SUB 2000
2540 LET dc=20: LET dr=5: LET f=0: GO SUB 2000
2550 RETURN
