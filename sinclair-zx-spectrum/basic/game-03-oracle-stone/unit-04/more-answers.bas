  10 CLS
  20 RANDOMIZE
  30 PRINT "The Oracle awaits your question."
  40 PRINT
  50 INPUT "Speak, mortal: "; q$
  60 PRINT
  70 PRINT "The Oracle ponders..."
  80 BEEP 0.3, 20: BEEP 0.3, 15: BEEP 0.3, 10: BEEP 0.3, 5
  90 PAUSE 25
 100 CLS
 110 LET r = INT (RND * 10) + 1
 120 BEEP 0.1, 24
 130 IF r = 1 THEN PRINT "YES"
 140 IF r = 2 THEN PRINT "NO"
 150 IF r = 3 THEN PRINT "PERHAPS"
 160 IF r = 4 THEN PRINT "ASK AGAIN LATER"
 170 IF r = 5 THEN PRINT "THE SIGNS ARE UNCLEAR"
 180 IF r = 6 THEN PRINT "DEFINITELY NOT"
 190 IF r = 7 THEN PRINT "THE STARS SAY YES"
 200 IF r = 8 THEN PRINT "NOT ON A TUESDAY"
 210 IF r = 9 THEN PRINT "THE ORACLE IS UNSURE"
 220 IF r = 10 THEN PRINT "WITHOUT A DOUBT"
